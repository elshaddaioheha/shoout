# Trigger Email (`firebase/firestore-send-email`) — copy values into the real `extensions/*.env`
# after `firebase ext:install firebase/firestore-send-email --project=<id>` (CLI writes the live file).
#
# MUST match backend: Cloud Functions use collection `mail` unless FIREBASE_TRIGGER_EMAIL_COLLECTION is set.

MAIL_COLLECTION=mail
DATABASE=(default)
DATABASE_REGION=us-central1
AUTH_TYPE=UsernamePassword
SMTP_CONNECTION_URI=smtps://user@smtp.example.com:465
SMTP_PASSWORD=
DEFAULT_FROM=billing@your-verified-domain.com
DEFAULT_REPLY_TO=support@your-verified-domain.com
TTL_EXPIRE_TYPE=never
TTL_EXPIRE_VALUE=1
