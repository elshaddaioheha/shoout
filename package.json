{
  "name": "shoouts",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:functions": "npm --prefix functions test",
    "dev:seed": "node ./scripts/seed.mjs",
    "dev:seed:test": "node ./scripts/seed-test-data.mjs",
    "dev:seed:full": "node ./scripts/seedFullData.mjs",
    "dev:seed:rest": "node ./scripts/seed-rest.mjs",
    "dev:seed:royalty-free": "node ./scripts/seed-royalty-free.mjs",
    "dev:seed:royalty-free-admin": "node ./scripts/seed-royalty-free-admin.mjs",
    "dev:seed:media": "node ./scripts/seed-media.mjs",
    "dev:seed:storage-sample": "node ./scripts/seed-storage-sample.mjs",
    "dev:seed:auth-admin": "node ./scripts/seed-auth-users-admin.mjs",
    "dev:backfill:publish-snapshot": "node ./scripts/backfill-publish-snapshot.mjs",
    "dev:backfill:publish-snapshot:apply": "node ./scripts/backfill-publish-snapshot.mjs --apply"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^8.7.0",
    "@stripe/stripe-react-native": "0.50.3",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "~16.0.8",
    "expo-blur": "^15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.10.0",
    "flutterwave-react-native": "^1.0.4",
    "lucide-react-native": "^0.564.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-module-scripts": "^55.0.2",
    "firebase-admin": "^13.7.0",
    "jest": "^30.2.0",
    "jest-expo": "^55.0.9",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/functions/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|lucide-react-native|zustand|expo-router|expo-constants|expo-modules-core|expo-font|expo-image|expo-document-picker|expo-linear-gradient|expo-blur|expo-haptics|expo-file-system|expo-av|expo-splash-screen|expo-linking|expo-web-browser)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^firebase$": "<rootDir>/__mocks__/firebase.ts",
      "^firebase/(.*)$": "<rootDir>/__mocks__/firebase.ts",
      "^@/firebaseConfig$": "<rootDir>/__mocks__/firebaseConfig.ts",
      "^../../firebaseConfig$": "<rootDir>/__mocks__/firebaseConfig.ts",
      "^../firebaseConfig$": "<rootDir>/__mocks__/firebaseConfig.ts",
      "expo-linear-gradient": "<rootDir>/__mocks__/expo-linear-gradient.js",
      "flutterwave-react-native": "<rootDir>/__mocks__/flutterwave-react-native.js",
      "expo/src/winter/(.*)$": "<rootDir>/__mocks__/expoRuntime.js",
      "expo/src/utils/getBundleUrl": "<rootDir>/__mocks__/expoRuntime.js"
    },
    "collectCoverageFrom": [
      "store/**/*.ts",
      "utils/**/*.ts",
      "!**/__mocks__/**",
      "!**/node_modules/**"
    ]
  }
}
