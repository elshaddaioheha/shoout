{
  "name": "shoouts",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:functions": "npm --prefix functions test",
    "dev:seed": "node ./scripts/seed.mjs",
    "dev:seed:test": "node ./scripts/seed-test-data.mjs",
    "dev:seed:full": "node ./scripts/seedFullData.mjs",
    "dev:seed:rest": "node ./scripts/seed-rest.mjs",
    "dev:seed:royalty-free": "node ./scripts/seed-royalty-free.mjs",
    "dev:seed:royalty-free-admin": "node ./scripts/seed-royalty-free-admin.mjs",
    "dev:seed:media": "node ./scripts/seed-media.mjs",
    "dev:seed:storage-sample": "node ./scripts/seed-storage-sample.mjs",
    "dev:seed:auth-admin": "node ./scripts/seed-auth-users-admin.mjs",
    "dev:backfill:publish-snapshot": "node ./scripts/backfill-publish-snapshot.mjs",
    "dev:backfill:publish-snapshot:apply": "node ./scripts/backfill-publish-snapshot.mjs --apply",
    "dev:backfill:publish-audio-url": "node ./scripts/backfill-publish-audio-url.mjs",
    "dev:backfill:publish-audio-url:apply": "node ./scripts/backfill-publish-audio-url.mjs --apply"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.11.0",
    "@stripe/stripe-react-native": "0.58.0",
    "expo": "~55.0.15",
    "expo-apple-authentication": "~55.0.13",
    "expo-av": "^16.0.8",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.13",
    "expo-dev-client": "~55.0.27",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-keep-awake": "~55.0.6",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.12",
    "expo-modules-core": "^55.0.22",
    "expo-notifications": "~55.0.18",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.14",
    "firebase": "^12.10.0",
    "flutterwave-react-native": "^1.0.4",
    "lucide-react-native": "^1.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-colors": "^2.6.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "^0.7.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/preset-modules": "^0.1.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "expo-module-scripts": "^55.0.2",
    "firebase-admin": "^13.7.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.15",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/functions/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|zustand|expo-router|expo-constants|expo-modules-core|expo-font|expo-image|expo-document-picker|expo-linear-gradient|expo-blur|expo-haptics|expo-file-system|expo-av|expo-splash-screen|expo-linking|expo-web-browser)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^firebase$": "<rootDir>/__mocks__/firebase.ts",
      "^firebase/(.*)$": "<rootDir>/__mocks__/firebase.ts",
      "^@/firebaseConfig$": "<rootDir>/__mocks__/firebaseConfig.ts",
      "^../../firebaseConfig$": "<rootDir>/__mocks__/firebaseConfig.ts",
      "^../firebaseConfig$": "<rootDir>/__mocks__/firebaseConfig.ts",
      "^expo-symbols$": "<rootDir>/__mocks__/expo-symbols.tsx",
      "expo-linear-gradient": "<rootDir>/__mocks__/expo-linear-gradient.js",
      "flutterwave-react-native": "<rootDir>/__mocks__/flutterwave-react-native.js",
      "expo/src/winter/(.*)$": "<rootDir>/__mocks__/expoRuntime.js",
      "expo/src/utils/getBundleUrl": "<rootDir>/__mocks__/expoRuntime.js"
    },
    "collectCoverageFrom": [
      "store/**/*.ts",
      "utils/**/*.ts",
      "!**/__mocks__/**",
      "!**/node_modules/**"
    ]
  }
}
