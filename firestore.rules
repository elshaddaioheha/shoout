rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidString(field) {
      return field is string && field.size() > 0;
    }

    function hasRestrictedUserFieldChange() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return 'role' in changed
        || 'actualRole' in changed
        || 'isPremium' in changed
        || 'subscriptionTier' in changed
        || 'subscriptionStatus' in changed
        || 'lastSubscribedAt' in changed
        || 'canSell' in changed
        || 'hasTeamAccess' in changed
        || 'hasAdvancedAnalytics' in changed
        || 'transactionFeePercent' in changed
        || 'storageLimitGB' in changed;
    }

    function hasSafeInitialUserRole() {
      return !('role' in request.resource.data)
        || request.resource.data.role in ['vault'];
    }

    // 🔒 CRITICAL: Backend-only writes via Admin SDK
    // This function explicitly blocks ALL client writes, making it impossible to
    // accidentally allow sensitive operations (payouts, transactions, etc.)
    // that should only be created by verified backend processes.
    function backendOnly() {
      return false; // Always blocks client writes; Admin SDK bypasses this rule
    }

    // 🔒 CRITICAL: Verify user has selling rights via subscription tier
    // Guards with exists() first — if there's no subscription doc the get() would
    // throw a permission-denied error even for free uploads.
    function canUserSell(uid) {
      let subPath = /databases/$(database)/documents/users/$(uid)/subscription/current;
      return exists(subPath)
        && get(subPath).data.tier in ['studio', 'hybrid']
        && get(subPath).data.isSubscribed == true;
    }

    function canReadPublishedUpload() {
      return isAuthenticated() || resource.data.isPublic == true;
    }

    // Client-only subscription writes: unpaid tier intent / vault baseline.
    // Paid activation (isSubscribed true, payment fields) is backend-only via Admin SDK.
    function clientSubscriptionUnpaidOk() {
      return request.resource.data.isSubscribed == false
        && request.resource.data.tier in ['vault', 'vault_pro', 'studio', 'hybrid'];
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Admin / Moderator Role Helpers
    // ─────────────────────────────────────────────────────────────────────────
    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isModerator() {
      return isAuthenticated() && getUserRole() in ['admin', 'moderator'];
    }

    function isAuditor() {
      return isAuthenticated() && getUserRole() in ['admin', 'moderator', 'auditor'];
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Users
    // Public profile is readable by anyone authenticated.
    // Only the owner can write their own document.
    // ─────────────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && hasSafeInitialUserRole();
      allow update: if isOwner(uid) && !hasRestrictedUserFieldChange();
      allow delete: if false; // Soft-delete only — never hard delete users

      // ── Subscription ───────────────────────────────────────────────────────
      // Owners can read current subscription. Owners can only create/update
      // a free vault baseline record; paid activations are backend-only.
      match /subscription/{subscriptionId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && clientSubscriptionUnpaidOk()
          && (!('status' in request.resource.data)
              || request.resource.data.status in ['free', 'trial']);
        allow delete: if false;
      }

      // ── Uploads (Vault / Studio) ──────────────────────────────────────────
      // Any authenticated user can READ uploads (for marketplace discovery).
      // Only the owner can write (upload, edit, delete).
      // Draft-first model:
      // - Drafts are private (`published != true` and `isPublic != true`) and always allowed for owner.
      // - Public publish with price > 0 requires active studio/hybrid subscription.
      // - Vault users can still publish free tracks.
      match /uploads/{uploadId} {
        allow read: if canReadPublishedUpload();

        allow create: if isOwner(uid)
          && isValidString(request.resource.data.title)
          && (
            // Draft/private create
            (
              request.resource.data.published != true
              && request.resource.data.isPublic != true
            )
            // Public free publish
            || request.resource.data.price == 0
            // Public paid publish (studio/hybrid only)
            || (
              request.resource.data.price > 0
              && canUserSell(uid)
            )
          );

        allow update: if isOwner(uid)
          && (
            // Private draft updates
            (
              request.resource.data.published != true
              && request.resource.data.isPublic != true
            )
            // Public free updates
            || request.resource.data.price == 0
            // Public paid updates
            || (
              request.resource.data.price > 0
              && canUserSell(uid)
            )
          );

        allow delete: if isOwner(uid);
      }

      // ── Purchases (Library) ───────────────────────────────────────────────
      // Only the owner can READ their own purchases.
      // WRITE ONLY by secure backend (Cloud Functions) after webhook verification.
      // Client cannot create, update, or delete.
      //
      // 🔒 CRITICAL SECURITY:
      // - Prevents users from granting themselves content access
      // - Prevents bypassing payment verification
      // - Backend must verify payment with Flutterwave/Stripe before creating
      match /purchases/{purchaseId} {
        allow read: if isOwner(uid);
        allow create: if backendOnly(); // 🔒 CRITICAL: Backend-only after payment verification
        allow update: if backendOnly(); // 🔒 CRITICAL: Immutable purchase record
        allow delete: if backendOnly(); // 🔒 CRITICAL: Immutable purchase record
      }

      // ── Notifications ─────────────────────────────────────────────────────
      // Only the owner can read and write their notifications.
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid); // e.g. mark as read
        allow delete: if isOwner(uid);
      }

      // ── Favourites ───────────────────────────────────────────────────────
      // Only the owner can read/write their favourites.
      match /favourites/{trackId} {
        allow read, write: if isOwner(uid);
      }

      // ── Vault Folders ────────────────────────────────────────────────────
      // Only the owner can manage their folders.
      match /folders/{folderId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.name);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);

        // ── Folder Tracks ───────────────────────────────────────────────────
        // Tracks added manually to a folder by the owner.
        match /tracks/{trackId} {
          allow read: if isOwner(uid);
          allow create: if isOwner(uid);
          allow update: if isOwner(uid);
          allow delete: if isOwner(uid);
        }
      }

      // ── Vault Share Links ────────────────────────────────────────────────
      // Only the owner can read and manage their private share links.
      match /vaultShares/{shareId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Playlists ─────────────────────────────────────────────────────────
      // Only the owner can read/write their playlists.
      match /playlists/{playlistId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidString(request.resource.data.name);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Publisher Profile ────────────────────────────────────────────────
      // Only the owner can read/write their publisher profile.
      match /publisherProfile/{profileId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Publisher Profile Audit ──────────────────────────────────────────
      // Only the owner can read and append audit entries.
      // Audit records are append-only from client side.
      match /publisherProfileAudit/{auditId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update, delete: if false;
      }

      // ── Ad Campaigns ─────────────────────────────────────────────────────
      // Only the owner can read and manage their own campaigns.
      match /campaigns/{campaignId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.headline)
          && isValidString(request.resource.data.goal)
          && isValidString(request.resource.data.adType);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Global Playlists
    // Shared playlist surface backed by owner-controlled writes and public reads.
    // Tracks are stored by reference (uploadId + uploaderId).
    // ─────────────────────────────────────────────────────────────────────────
    match /globalPlaylists/{playlistId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && isValidString(request.resource.data.name);
      allow update, delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      match /tracks/{trackRefId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && get(/databases/$(database)/documents/globalPlaylists/$(playlistId)).data.ownerId == request.auth.uid
          && isValidString(request.resource.data.uploadId)
          && isValidString(request.resource.data.uploaderId);
        allow update, delete: if isAuthenticated()
          && get(/databases/$(database)/documents/globalPlaylists/$(playlistId)).data.ownerId == request.auth.uid;
      }
    }


    // ─────────────────────────────────────────────────────────────────────────
    // Transactions (Marketplace purchases)
    // Any authenticated user can READ their own transactions (buyer or seller).
    // WRITE ONLY by secure backend (Cloud Functions) after webhook verification.
    // Client cannot create, update, or delete (audit trail enforcement).
    //
    // 🔒 CRITICAL SECURITY:
    // - Prevents users from creating fake transactions
    // - Prevents bypassing payment verification
    // - Backend must verify payment with Flutterwave/Stripe before creating
    // ─────────────────────────────────────────────────────────────────────────
    match /transactions/{txnId} {
      allow read: if isAuthenticated()
        && (resource.data.buyerId == request.auth.uid
            || resource.data.sellerId == request.auth.uid);
      allow create: if backendOnly(); // 🔒 CRITICAL: Backend-only after payment verification
      allow update: if backendOnly(); // 🔒 CRITICAL: Immutable audit trail
      allow delete: if backendOnly(); // 🔒 CRITICAL: Immutable audit trail
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Payouts
    // Only the earner can read their own payouts.
    // WRITE ONLY by secure backend (Admin SDK or Cloud Functions).
    // Client cannot create, update, or delete.
    //
    // 🔒 CRITICAL SECURITY:
    // - Prevents users from forging payout requests
    // - Prevents draining the platform via spam payouts
    // - Backend must verify earnings before creating payout documents
    // ─────────────────────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if backendOnly(); // 🔒 CRITICAL: Backend-only via Admin SDK
      allow update: if backendOnly(); // 🔒 CRITICAL: Backend-only via Admin SDK
      allow delete: if backendOnly(); // 🔒 CRITICAL: Backend-only via Admin SDK
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Chats
    // A chat is readable/writable only by its participants.
    // ─────────────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // ── Messages ──────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && isValidString(request.resource.data.text);
        allow update: if false; // No editing messages
        allow delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Uploads (Transcoding Metadata for HLS + Watermarking)
    // Tracks progress of audio file transcoding to watermarked HLS format.
    // Readable by authenticated users to check transcoding status.
    // Written ONLY by backend (Cloud Functions via Admin SDK).
    //
    // 🎵 ANTI-PIRACY STREAMING MODEL:
    // - Raw file: originals/{userId}/{trackId}.wav (backend-only storage path)
    // - HLS preview: hls-previews/{userId}/{trackId}/*.m3u8 (watermarked chunks)
    // - Status tracking: uploads/{trackId} (this collection)
    //
    // ─────────────────────────────────────────────────────────────────────────
    match /uploads/{uploadId} {
      // Users can read upload metadata (to check transcoding progress).
      // Public discovery queries also reuse this collection name, so anonymous
      // reads are allowed only for uploads that were explicitly published.
      allow read: if canReadPublishedUpload();
      
      // Backend-only writes via Cloud Functions
      allow create: if backendOnly(); // 🔒 CRITICAL: Triggered by processAudioUpload()
      allow update: if backendOnly(); // 🔒 CRITICAL: Updated by onHlsTranscodingComplete()
      allow delete: if backendOnly(); // 🔒 CRITICAL: Cleanup via backend job
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Public Upload Discovery
    // Collection-group queries over any uploads subtree need a recursive rule.
    // This keeps reads consistent for published tracks while leaving writes
    // locked to the owner/backend-specific rules above.
    // ─────────────────────────────────────────────────────────────────────────
    match /{path=**}/uploads/{uploadId} {
      allow read: if canReadPublishedUpload();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Moderation & Compliance
    // ─────────────────────────────────────────────────────────────────────────
    match /contentReports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isModerator();
      allow update: if isModerator();
      allow delete: if false;
    }

    match /moderationLog/{logId} {
      allow read: if isAuditor();
      allow create: if backendOnly();
      allow update: if backendOnly();
      allow delete: if backendOnly();
    }

    // Optional audit ledger for payout-related actions
    match /payoutLedger/{entryId} {
      allow read: if isAuditor();
      allow create: if backendOnly();
      allow update: if backendOnly();
      allow delete: if backendOnly();
    }

    match /users/{uid}/payouts/{payoutId} {
      allow read: if isOwner(uid) || isAuditor();
      allow create: if backendOnly();
      allow update: if backendOnly();
      allow delete: if backendOnly();
    }

    // Outbound email queue for Trigger Email extension — written only via Admin SDK / extension
    match /mail/{mailId} {
      allow read, write: if false;
    }
  }
}
