rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidString(field) {
      return field is string && field.size() > 0;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Users
    // Public profile is readable by anyone authenticated.
    // Only the owner can write their own document.
    // ─────────────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false; // Soft-delete only — never hard delete users

      // ── Uploads (Vault / Studio) ──────────────────────────────────────────
      // Any authenticated user can READ uploads (for marketplace discovery).
      // Only the owner can write (upload, edit, delete).
      match /uploads/{uploadId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.title)
          && request.resource.data.price >= 0;
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Purchases (Library) ───────────────────────────────────────────────
      // Only the owner can read their own purchases.
      // Purchases are written by the owner (checkout flow) or internally.
      match /purchases/{purchaseId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.title);
        allow update: if false; // Purchases are immutable
        allow delete: if false;
      }

      // ── Notifications ─────────────────────────────────────────────────────
      // Only the owner can read and write their notifications.
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid); // e.g. mark as read
        allow delete: if isOwner(uid);
      }
    }


    // ─────────────────────────────────────────────────────────────────────────
    // Transactions (Marketplace purchases)
    // Any authenticated user can CREATE (buy).
    // Only the buyer or seller can READ their own transactions.
    // Nobody can UPDATE or DELETE (audit trail).
    // ─────────────────────────────────────────────────────────────────────────
    match /transactions/{txnId} {
      allow read: if isAuthenticated()
        && (resource.data.buyerId == request.auth.uid
            || resource.data.sellerId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.amount >= 0
        && isValidString(request.resource.data.trackTitle);
      allow update: if false;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Payouts
    // Only the earner can read. System writes (admin SDK) for now.
    // ─────────────────────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Chats
    // A chat is readable/writable only by its participants.
    // ─────────────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // ── Messages ──────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && isValidString(request.resource.data.text);
        allow update: if false; // No editing messages
        allow delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Merch Store
    // Public discovery — any authenticated user can read active listings.
    // Only admins / the store owner write merch (managed via Admin SDK).
    // ─────────────────────────────────────────────────────────────────────────
    match /merch/{itemId} {
      allow read: if isAuthenticated() && resource.data.active == true;
      allow create, update, delete: if false; // Admin SDK only
    }

  }
}
