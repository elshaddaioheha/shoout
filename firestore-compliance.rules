rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // HELPERS & ACCESS CONTROL
    // ─────────────────────────────────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    function isValidString(field) {
      return field is string && field.size() > 0;
    }

    function backendOnly() {
      return false;  // CRITICAL: Blocks all client writes
    }

    function canUserSell(uid) {
      let userSub = get(/databases/$(database)/documents/users/$(uid)/subscription/current);
      return userSub.data.tier in ['studio_free', 'studio_pro', 'studio_plus', 'hybrid_creator', 'hybrid_executive'];
    }

    // ─────────────────────────────────────────────────────────────────────────
    // PAYMENT & PAYOUT COMPLIANCE (READ-ONLY LEDGER MODEL)
    // ─────────────────────────────────────────────────────────────────────────

    // Payout Ledger: Backend-only immutable audit trail
    match /payoutLedger/{payoutId} {
      // Anyone can read for transparency (except sensitive fields)
      allow read: if isAuthenticated();
      
      // Backend only: Cloud Functions create entries after Stripe transfer
      allow create: if backendOnly();
      allow update: if backendOnly();
      allow delete: if backendOnly();
    }

    // Creator's personal payout records
    match /users/{uid}/payouts/{payoutId} {
      // Only owner can read their own payouts
      allow read: if isOwner(uid);
      
      // Backend creates after Stripe transfer succeeds
      allow create: if backendOnly();
      allow update: if backendOnly();  // Status updates only from backend
      allow delete: if backendOnly();  // Immutable record
    }

    // Creator's payout history (for display in app)
    match /users/{uid}/payoutHistory/{historyId} {
      allow read: if isOwner(uid);
      allow write: if backendOnly();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // STRIPE CONNECT KYC DATA (SENSITIVE - READ-ONLY)
    // ─────────────────────────────────────────────────────────────────────────
    
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;

      // Stripe Connect KYC status (user can see, not edit)
      // Only Stripe webhooks can update these fields
      match /{document=**} {
        allow read: if isOwner(uid);
        // Backend only: stripeWebhook() updates kycStatus, suspension fields
        allow write: if backendOnly();
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // CONTENT MODERATION & DMCA (ADMIN-ONLY)
    // ─────────────────────────────────────────────────────────────────────────

    // Content Reports: Community flagging system
    match /contentReports/{reportId} {
      // 🔒 CRITICAL: Only admins and reporter can read
      allow read: if isAdmin() || 
                    (isAuthenticated() && resource.data.reporterId == request.auth.uid);
      
      // Community can submit reports
      allow create: if isAuthenticated() && 
                       isValidString(request.resource.data.reason) &&
                       request.resource.data.reason in ['copyright', 'offensive', 'spam'];
      
      // Backend/Admin only: Update status after review
      allow update: if isAdmin() && 
                       (request.resource.data.status in ['reviewed'] ||
                        request.resource.data.decision in ['upheld', 'dismissed']);
      
      allow delete: if false;  // Immutable for audit trail
    }

    // Moderation Log: Admin actions (audit trail)
    match /moderationLog/{logId} {
      allow read: if isAdmin();  // Admins only
      allow write: if backendOnly();  // Backend only
    }

    // Refunds: Backend-managed (from upheld reports)
    match /refunds/{refundId} {
      // Buyer can read their refund
      allow read: if isAuthenticated() && resource.data.buyerId == request.auth.uid;
      
      // Backend only: Create refunds after upholding report
      allow create: if backendOnly();
      allow update: if backendOnly();  // Status: pending → processed
      allow delete: if false;  // Immutable record
    }

    // ─────────────────────────────────────────────────────────────────────────
    // USER UPLOADS (WITH ENFORCEMENT & COMPLIANCE)
    // ─────────────────────────────────────────────────────────────────────────
    
    match /users/{uid}/uploads/{uploadId} {
      allow read: if isAuthenticated();
      
      allow create: if isOwner(uid)
        && isValidString(request.resource.data.title)
        && request.resource.data.price >= 0
        && (request.resource.data.price == 0 || canUserSell(uid))
        && !get(/databases/$(database)/documents/users/$(uid)).data.canUpload == false;
      
      allow update: if isOwner(uid);
      
      allow delete: if isOwner(uid);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // PURCHASES & TRANSACTIONS (IMMUTABLE LEDGER)
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{uid}/purchases/{purchaseId} {
      allow read: if isOwner(uid);
      allow create: if backendOnly();  // After Flutterwave verification
      allow update: if backendOnly();  // Status changes only from backend
      allow delete: if backendOnly();
    }

    match /transactions/{txnId} {
      allow read: if isAuthenticated() && 
                    (resource.data.buyerId == request.auth.uid ||
                     resource.data.sellerId == request.auth.uid);
      allow create: if backendOnly();
      allow update: if backendOnly();
      allow delete: if backendOnly();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // CHATS & SOCIAL
    // ─────────────────────────────────────────────────────────────────────────

    match /chats/{chatId} {
      allow read: if isAuthenticated() && 
                    request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      allow update: if isAuthenticated() && 
                     request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // NOTIFICATIONS
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{uid}/notifications/{notifId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) || backendOnly();
      allow update: if isOwner(uid);  // Mark as read
      allow delete: if isOwner(uid);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // SYSTEM & METADATA (READ-ONLY)
    // ─────────────────────────────────────────────────────────────────────────

    match /system/{document=**} {
      allow read: if isAuthenticated();
      allow write: if backendOnly();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // ADMIN DASHBOARD ACCESS
    // ─────────────────────────────────────────────────────────────────────────

    match /admin/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin() && request.method == 'update';  // Limited edits
    }

    // ─────────────────────────────────────────────────────────────────────────
    // DENY EVERYTHING ELSE
    // ─────────────────────────────────────────────────────────────────────────

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
