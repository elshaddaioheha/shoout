rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAudio() {
      return request.resource.contentType.matches('audio/.*');
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function maxSize(mb) {
      return request.resource.size <= mb * 1024 * 1024;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // ANTI-PIRACY: Secure Audio Storage Paths
    // ─────────────────────────────────────────────────────────────────────────
    // originals/{userId}/{trackId}.wav - Backend-only, purchase-verified access
    // hls-previews/{userId}/{trackId}/* - Watermarked chunks, signed URL access
    // vaults/{userId}/{filename} - Temporary upload staging
    // ─────────────────────────────────────────────────────────────────────────

    // SECURE ORIGINALS: Backend-only write via Cloud Functions
    match /originals/{userId}/{trackId}.wav {
      allow read: if false; // NO CLIENT READ
      allow create, write: if false; // Admin SDK only
      allow delete: if false;
    }

    // HLS PREVIEWS: Watermarked chunks for marketplace
    match /hls-previews/{userId}/{trackId}/{segment=**} {
      allow read: if false; // Signed URLs only
      allow write: if false; // Backend only
      allow delete: if false;
    }

    // VAULTS: Temporary upload staging area
    match /vaults/{userId}/{filename} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isAudio() && maxSize(200);
      allow delete: if false; // Admin SDK handles cleanup
    }

    // ─────────────────────────────────────────────────────────────────────────
    // User Audio Uploads (Vault / Studio)
    // Path: users/{uid}/audio/{filename}
    // ─────────────────────────────────────────────────────────────────────────
    match /users/{uid}/audio/{filename} {
      // Anyone authenticated can read (stream) audio files
      allow read: if isAuthenticated();

      // Only the owner can upload — max 200MB per file
      allow create: if isOwner(uid)
        && isAudio()
        && maxSize(200);

      // Owner can replace (re-upload) files
      allow update: if isOwner(uid) && isAudio();

      // Owner can delete their own files
      allow delete: if isOwner(uid);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Cover Art / Thumbnails
    // Path: users/{uid}/covers/{filename}
    // ─────────────────────────────────────────────────────────────────────────
    match /users/{uid}/covers/{filename} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid)
        && isImage()
        && maxSize(10);
      allow update: if isOwner(uid) && isImage();
      allow delete: if isOwner(uid);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // User Avatar / Profile Picture
    // Path: avatars/{uid}
    // ─────────────────────────────────────────────────────────────────────────
    match /avatars/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid)
        && isImage()
        && maxSize(5);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Merch Product Images (admin-only writes)
    // Path: merch/{itemId}/{filename}
    // ─────────────────────────────────────────────────────────────────────────
    match /merch/{itemId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // ─────────────────────────────────────────────────────────────────────────
    // System Metadata (read-only for clients)
    // ─────────────────────────────────────────────────────────────────────────
    match /system/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Deny everything else
    // ─────────────────────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
