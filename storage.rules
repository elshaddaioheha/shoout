rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isAudio() {
      return request.resource.contentType != null
        && request.resource.contentType.matches('audio/.*');
    }

    function isVaultAudioUpload(path) {
      return isAudio()
        || path.matches('.*[.]mp3$')
        || path.matches('.*[.]m4a$')
        || path.matches('.*[.]wav$')
        || path.matches('.*[.]aac$')
        || path.matches('.*[.]mp4$');
    }

    function isVideo() {
      return request.resource.contentType != null
        && request.resource.contentType.matches('video/.*');
    }

    function isImage() {
      return request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    function maxSize(mb) {
      return request.resource.size <= mb * 1024 * 1024;
    }

    match /originals/{userId}/{trackFile} {
      allow read, write: if false;
    }

    match /hls-previews/{userId}/{trackId}/{segment=**} {
      allow read, write: if false;
    }

    match /vaults/{userId}/covers/{filename} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && isImage()
        && maxSize(10);

      allow update: if isOwner(userId)
        && isImage()
        && maxSize(10);

      allow delete: if isOwner(userId) || isAdmin();
    }

    match /vaults/{userId}/recordings/{filename} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && maxSize(200);

      allow update: if isOwner(userId)
        && maxSize(200)
        && isVaultAudioUpload(filename);

      allow delete: if isOwner(userId) || isAdmin();
    }

    match /vaults/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && maxSize(200)
        && (
          (allPaths.matches('conversion-inputs/.*') && isVideo()) ||
          (!allPaths.matches('conversion-inputs/.*') && isVaultAudioUpload(allPaths))
        );

      allow update: if isOwner(userId)
        && maxSize(200)
        && (
          (allPaths.matches('conversion-inputs/.*') && isVideo()) ||
          (!allPaths.matches('conversion-inputs/.*') && isVaultAudioUpload(allPaths))
        );

      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{uid}/audio/{filename} {
      allow read: if false;

      allow create: if isOwner(uid)
        && isAudio()
        && maxSize(50);

      allow update: if isOwner(uid)
        && isAudio()
        && maxSize(50);

      allow delete: if isOwner(uid) || isAdmin();
    }

    match /users/{uid}/covers/{filename} {
      allow read: if true;

      allow create: if isOwner(uid)
        && isImage()
        && maxSize(10);

      allow update: if isOwner(uid)
        && isImage()
        && maxSize(10);

      allow delete: if isOwner(uid) || isAdmin();
    }

    match /avatars/{uid} {
      allow read: if true;

      allow write: if isOwner(uid)
        && isImage()
        && maxSize(5);
    }

    match /system/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}