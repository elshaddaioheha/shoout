{
    "cli": {
        "version": ">= 14.1.0",
        "promptToConfigurePushNotifications": false,
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "GOOGLE_SERVICES_JSON": "google-services.json"
            }
        },
        "production": {
            "autoIncrement": true
        }
    },
    "submit": {
        "production": {}
    }
}