{
    "cli": {
        "version": ">= 14.1.0",
        "promptToConfigurePushNotifications": false,
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "autoIncrement": true,
            "android": {
                "buildType": "apk",
                "googleServicesFile": "./google-services.json"
            }
        },
        "production": {
            "channel": "production",
            "autoIncrement": true
        }
    },
    "submit": {
        "production": {}
    }
}