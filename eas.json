{
    "cli": {
        "version": ">= 14.1.0",
        "promptToConfigurePushNotifications": false,
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "autoIncrement": "version",
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "channel": "production",
            "autoIncrement": "version"
        }
    },
    "submit": {
        "production": {}
    },
    "update": {
        "development": {
            "channel": "development"
        },
        "preview": {
            "channel": "preview"
        },
        "production": {
            "channel": "production"
        }
    }
}